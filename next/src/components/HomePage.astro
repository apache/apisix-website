---
/** Full port of the production homepage: same sections, same copy, zero JS. */
import Base from '../layouts/Base.astro';
import { t, localePrefix, SOCIAL_IMAGE, type Locale } from '../lib/site';

interface Props { locale: Locale }
const { locale } = Astro.props;
const p = localePrefix(locale);

const STATS = [
  ['100+', t(locale, 'plugins', '插件')],
  ['~18k', t(locale, 'QPS / core', '单核 QPS')],
  ['0.2 ms', t(locale, 'added latency', '额外延迟')],
  ['Apache 2.0', t(locale, 'licensed', '开源协议')],
];

const QUICK_CARDS = [
  { title: t(locale, 'Get started', '快速开始'), body: t(locale, 'Install APISIX and configure your first route in minutes.', '几分钟内安装 APISIX 并配置你的第一条路由。'), link: t(locale, 'Read the docs →', '阅读文档 →'), href: `${p}/docs/apisix/getting-started/README/` },
  { title: t(locale, 'Learn the concepts', '学习核心概念'), body: t(locale, 'API gateway, AI gateway, rate limiting, mTLS, Kubernetes and more.', 'API 网关、AI 网关、限流限速、mTLS、Kubernetes 等。'), link: t(locale, 'Explore the learning center →', '进入学习中心 →'), href: `${p}/learning-center/` },
  { title: t(locale, 'Case studies', '用户案例'), body: t(locale, 'See how teams run Apache APISIX in production at scale.', '看看各团队如何在生产环境大规模运行 Apache APISIX。'), link: t(locale, 'Read case studies →', '阅读用户案例 →'), href: `${p}/blog/` },
];

const AI_PROVIDERS = ['OpenAI', 'Anthropic', 'AWS Bedrock', 'DeepSeek', 'Ollama', '+ more'];
// title, description, doc link. Mirrors website/src/.../AIGatewaySection.tsx.
const AI_CARDS: [string, string, string][] = [
  ['Multi-LLM proxy', 'Route to OpenAI, Anthropic, AWS Bedrock, DeepSeek, Ollama and 20+ providers through one endpoint.', '/docs/apisix/plugins/ai-proxy/'],
  ['LLM load balancing', 'Distribute traffic across providers and models for throughput and resilience.', '/docs/apisix/plugins/ai-proxy-multi/'],
  ['Retry & fallback', 'Fail over to a backup model or provider automatically when one is unavailable.', '/docs/apisix/plugins/ai-proxy-multi/'],
  ['Token rate limiting', 'Cap usage and cost with token-based rate limits per consumer.', '/docs/apisix/plugins/ai-rate-limiting/'],
  ['Prompt security', 'Guardrails, content moderation, and prompt decoration before requests reach the model.', '/docs/apisix/plugins/ai-prompt-guard/'],
  ['MCP support', 'Expose and govern Model Context Protocol tools through the gateway.', '/ai-gateway/'],
];

// name, brand icon/logo under /img/integrations/ (null = text-only chip), and
// the plugin/discovery doc it links to. Mirrors website/src/.../Integrations.tsx.
const INTEGRATIONS: { name: string; img: string | null; href: string }[] = [
  { name: 'Prometheus', img: '/img/integrations/icon-prometheus.svg', href: '/docs/apisix/plugins/prometheus/' },
  { name: 'Grafana', img: '/img/integrations/grafana.svg', href: '/docs/apisix/plugins/prometheus/' },
  { name: 'Datadog', img: '/img/integrations/icon-datadog.svg', href: '/docs/apisix/plugins/datadog/' },
  { name: 'OpenTelemetry', img: '/img/integrations/opentelemetry.svg', href: '/docs/apisix/plugins/opentelemetry/' },
  { name: 'Apache SkyWalking', img: '/img/integrations/icon-skywalking.svg', href: '/docs/apisix/plugins/skywalking/' },
  { name: 'Zipkin', img: '/img/integrations/icon-zipkin.svg', href: '/docs/apisix/plugins/zipkin/' },
  { name: 'Elasticsearch', img: '/img/integrations/elasticsearch.svg', href: '/docs/apisix/plugins/elasticsearch-logger/' },
  { name: 'ClickHouse', img: '/img/integrations/clickhouse.svg', href: '/docs/apisix/plugins/clickhouse-logger/' },
  { name: 'Google Cloud', img: '/img/integrations/icon-google-cloud-logging.svg', href: '/docs/apisix/plugins/google-cloud-logging/' },
  { name: 'Apache Kafka', img: '/img/integrations/icon-kafka-logger.svg', href: '/docs/apisix/plugins/kafka-logger/' },
  { name: 'gRPC', img: '/img/integrations/icon-grpc-transcode.svg', href: '/docs/apisix/plugins/grpc-transcode/' },
  { name: 'Kubernetes', img: '/img/integrations/kubernetes.svg', href: '/docs/apisix/discovery/kubernetes/' },
  { name: 'Consul', img: '/img/integrations/consul.svg', href: '/docs/apisix/discovery/consul/' },
  { name: 'NGINX', img: '/img/integrations/nginx.svg', href: '/docs/apisix/architecture-design/apisix/' },
  { name: 'Redis', img: '/img/integrations/redis.svg', href: '/docs/apisix/plugins/limit-count/' },
  { name: 'OpenID Connect', img: '/img/integrations/icon-openid-connect.svg', href: '/docs/apisix/plugins/openid-connect/' },
  { name: 'Keycloak', img: '/img/integrations/icon-authz-keycloak.svg', href: '/docs/apisix/plugins/authz-keycloak/' },
  { name: 'Casbin', img: '/img/integrations/casbin.png', href: '/docs/apisix/plugins/authz-casbin/' },
  { name: 'HashiCorp Vault', img: '/img/integrations/vault.svg', href: '/docs/apisix/terminology/secret/' },
  { name: 'OpenAI', img: null, href: '/docs/apisix/plugins/ai-proxy/' },
  { name: 'Anthropic', img: null, href: '/docs/apisix/plugins/ai-proxy/' },
  { name: 'AWS Bedrock', img: null, href: '/docs/apisix/plugins/ai-proxy/' },
  { name: 'DeepSeek', img: null, href: '/docs/apisix/plugins/ai-proxy/' },
  { name: 'Ollama', img: null, href: '/docs/apisix/plugins/ai-proxy/' },
];

const PILLARS = [
  {
    kicker: t(locale, 'Performance', '性能'),
    title: t(locale, 'Ultimate performance', '极致的性能体验'),
    body: t(locale,
      'Apache APISIX Gateway uses radixtree-route-matching and etcd under the hood to provide you the ability to create high speed synchronized systems. From routing to built-in plugins, all these are designed and implemented to be uber performant with the minimum latency possible.',
      'Apache APISIX 基于 Radixtree Route 和 etcd 提供路由极速匹配与配置快速同步的能力。从路由到插件，所有的设计和实现都是为了极速性能和超低延迟。'),
  },
  {
    kicker: t(locale, 'Security', '安全'),
    title: t(locale, 'Shield against the malicious', '阻拦恶意程序'),
    body: t(locale,
      'Apache APISIX Gateway provides multiple security plugins for identity authentication and API verification, including CORS, JWT, Key Auth, OpenID Connect (OIDC), Keycloak, etc. We put stability and security first.',
      'Apache APISIX 提供了多款身份认证与接口验证的插件，我们将稳定、安全放在首位。如需了解更多信息请查看安全类插件。'),
  },
  {
    kicker: t(locale, 'Scalability and availability', '高可用与可扩展性'),
    title: t(locale, 'Scales with your users', '与用户一起扩容'),
    body: t(locale,
      'Apache APISIX Gateway provides the ability to write your own custom plugins, use custom Load Balancing Algorithms during the balancer phase for scaling and custom Routing algorithms for fine control on routing.',
      'Apache APISIX 提供了自定义插件的能力，你可以在 Balancer 阶段使用自定义负载均衡算法，并使用自定义路由算法对路由进行精细化控制。'),
  },
  {
    kicker: t(locale, 'Fully dynamic', '完全动态'),
    title: t(locale, 'Save dev-time, design what matters', '热更新，节省开发时间'),
    body: t(locale,
      'As API Gateway, Apache APISIX provides Hot updates and Hot plugins, which continuously update configurations without restarts, saving development time and stress. In addition, health checks, circuit breakers, and many more features keep the system balanced.',
      'Apache APISIX 提供热更新、插件热加载能力，在不重新启动实例的情况下可快速更新配置，这能够节省开发时间并降低服务压力。同时，健康检查、服务熔断以及其它功能可以让系统始终保持稳定、可靠。'),
  },
  {
    kicker: t(locale, 'Multi-platform and protocol', '多平台、多协议'),
    title: t(locale, 'Create once, run anywhere', '一次创建，随处运行'),
    body: t(locale,
      "Platform agnostic, no vendor lock-in. Apache APISIX as API Management solution, can run from bare-metal to Kubernetes. It supports HTTP to gRPC transcoding, websockets, gRPC, Dubbo, MQTT proxy and multiple platforms including ARM64, don't worry about the lock-in of the infra technology.",
      'Apache APISIX 提供了多平台解决方案，它不但支持在裸机运行，也支持在 Kubernetes 中使用。它支持 HTTP 到 gRPC 的转换、WebSockets、gRPC、Dubbo、MQTT 代理和包括 ARM64 在内的多个平台，无需担心供应商对基础设施技术的锁定。'),
  },
];

// Infographic per pillar, same order as PILLARS. Ported from Benefits.tsx (as
// static art — the production GSAP timelines are replaced by CSS reveal).
const PILLAR_IMGS = [
  { src: '/img/infographs/performance.svg', w: 603, h: 746 },
  { src: '/img/infographs/security.svg', w: 1783, h: 787 },
  { src: '/img/infographs/scale.svg', w: 998, h: 779 },
  { src: '/img/infographs/dynamic.svg', w: 1057, h: 640 },
  { src: '/img/infographs/multiplatform.svg', w: 543, h: 244 },
];

---
<Base
  title={t(locale, 'Apache APISIX - Open Source API Gateway & AI Gateway', 'Apache APISIX - 开源 API 网关与 AI 网关')}
  titleSuffix={false}
  description={t(locale,
    'Apache APISIX is a dynamic, high-performance, open-source API gateway and AI gateway. Features include load balancing, authentication, rate limiting, AI proxying, LLM load balancing, and 100+ plugins.',
    'Apache APISIX 是一个动态、高性能的开源 API 网关和 AI 网关，提供负载均衡、身份认证、限流限速、AI 代理、LLM 负载均衡等能力和 100+ 插件。')}
  locale={locale}
  path="/"
  image={SOCIAL_IMAGE}
>
  <section class="hero">
    <div class="container">
      <p class="asf-badge">{t(locale, 'Apache Software Foundation top-level project', 'Apache 软件基金会顶级项目')}</p>
      <h1>{t(locale, 'The open-source API Gateway & AI Gateway', '开源 API 网关与 AI 网关')}</h1>
      <p class="lead">
        {t(locale,
          'High-performance traffic management for APIs, microservices, and LLM workloads — dynamic routing, load balancing, authentication, observability, and 100+ plugins.',
          '面向 API、微服务与 LLM 工作负载的高性能流量管理——动态路由、负载均衡、身份认证、可观测性与 100+ 插件。')}
      </p>
      <div class="btn-row">
        <a class="btn" href={`${p}/docs/apisix/getting-started/README/`}>{t(locale, 'Get started', '快速开始')}</a>
        <a class="btn ghost" href={`${p}/plugins/`}>{t(locale, 'Browse 100+ plugins', '浏览 100+ 插件')}</a>
      </div>
      <ul class="stat-row" role="list">
        {STATS.map(([v, l]) => <li class="stat"><strong>{v}</strong><span>{l}</span></li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <h2 class="visually-hidden">{t(locale, 'Get started with Apache APISIX', '快速开始')}</h2>
    <div class="container grid-3 pathways">
      {QUICK_CARDS.map((c) => (
        <a class="card" href={c.href}><h3>{c.title}</h3><p>{c.body}</p><p class="card-link">{c.link}</p></a>
      ))}
    </div>
  </section>

  <section class="section alt ai-gateway">
    <div class="container">
      <p class="badge">AI Gateway</p>
      <h2>{t(locale, 'The same gateway, now for your LLM traffic', '同一个网关，现在服务你的 LLM 流量')}</h2>
      <p class="sub">{t(locale,
        'Proxy, secure, and govern traffic to 20+ LLM providers — with the performance, plugins, and observability you already run for your APIs.',
        '代理、保护并治理发往 20+ LLM 提供商的流量——复用你已经在 API 上运行的性能、插件与可观测能力。')}</p>
      <p class="chip-row">
        <span class="flow-step"><span class="chip flow">{t(locale, 'AI apps & agents', 'AI 应用与智能体')}</span><span class="arrow">→</span></span>
        <span class="flow-step"><span class="chip flow strong">Apache APISIX</span><span class="arrow">→</span></span>
        {AI_PROVIDERS.map((n) => <span class="chip">{n}</span>)}
      </p>
      <div class="grid-3">
        {AI_CARDS.map(([h, b, href]) => <a class="card" href={`${p}${href}`}><h3>{h}</h3><p>{b}</p></a>)}
      </div>
      <p style="margin-top:2rem"><a class="cta-link" href={`${p}/ai-gateway/`}>{t(locale, 'Explore the AI Gateway →', '了解 AI 网关 →')}</a></p>
    </div>
  </section>

  <section class="section arch">
    <div class="container">
      <p class="kicker">{t(locale, 'Architecture', '架构')}</p>
      <h2>{t(locale, 'Dynamic by design, built on NGINX and etcd', '为动态而生，基于 NGINX 与 etcd')}</h2>
      <p class="sub">{t(locale,
        'Requests flow through a hot-reloadable plugin pipeline; etcd distributes configuration across the cluster in real time, with no restarts.',
        '请求流经可热加载的插件流水线；etcd 将配置实时分发到整个集群，无需重启。')}</p>
      <figure class="arch-visual reveal">
        <img src="/img/architecture.svg" alt={t(locale, 'Apache APISIX architecture diagram', 'Apache APISIX 架构图')} loading="lazy" width="1713" height="996" />
        <figcaption>{t(locale,
          'Apache APISIX is based on NGINX and etcd. Compared with traditional API Gateways, APISIX has features like dynamic routing and hot-loading plugins, etc.',
          'Apache APISIX 基于 NGINX 与 etcd，相较于传统的 API 网关，它提供了动态路由、插件热加载等诸多能力。')}</figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t(locale, 'Building for large-scale, high value systems', '适用于超大规模、复杂的业务系统')}</h2>
      <p class="sub">{t(locale,
        'Apache APISIX provides open source API Gateway to help you manage microservices, delivering the ultimate performance, security, and scalable platform for all your APIs and microservices.',
        'Apache APISIX 作为云原生架构的开源 API 网关，可以为海量 API 和微服务提供安全可靠的动态、高性能、可扩展的管理平台。')}</p>
      <div class="why-block">
        <p class="badge solid">{t(locale, 'Why APISIX API Gateway?', '为什么选择 APISIX API 网关？')}</p>
        <h3 class="feature-headline">{t(locale,
          'Reduce time fighting bugs, focus on designing world-class systems with API Gateway',
          'Apache APISIX 值得信赖，你只需专注在具体业务中，而无需考虑 API 处理基础组件。')}</h3>
        <p class="feature-lead">{t(locale,
          'APISIX API Gateway offers nearly 100 open-source plugins, comprehensive API management capabilities, and advanced technical advantages.',
          'APISIX API 网关提供近百个开源插件、全面的 API 管理能力和先进的技术优势。')}</p>
      </div>
    </div>
  </section>

  <section class="section alt integrations">
    <div class="container">
      <h2>{t(locale, 'Integrates with your stack', '与你的技术栈无缝集成')}</h2>
      <p class="sub">{t(locale,
        'Connect APISIX to your observability, security, service discovery, and AI tools through 100+ plugins.',
        '通过 100+ 插件，将 APISIX 接入你的可观测、安全、服务发现与 AI 工具。')}</p>
      <div class="chip-row logos">{INTEGRATIONS.map((it) => (
        <a class="chip logo" href={`${p}${it.href}`} title={it.name}>
          {it.img && <img src={it.img} alt="" width="30" height="30" loading="lazy" />}
          <span>{it.name}</span>
        </a>
      ))}</div>
      <p style="margin-top:2rem"><a class="cta-link" href={`${p}/plugins/`}>{t(locale, 'Explore all 100+ plugins →', '浏览全部 100+ 插件 →')}</a></p>
    </div>
  </section>

  {PILLARS.map((s, i) => (
    <section class="section pillar-section">
      <div class={`container pillar${i % 2 ? ' flip' : ''}`}>
        <div class="pillar-text">
          <p class="kicker">{s.kicker}</p>
          <h2>{s.title}</h2>
          <p class="sub">{s.body}</p>
        </div>
        <div class="pillar-visual reveal">
          <img src={PILLAR_IMGS[i].src} alt="" loading="lazy" width={PILLAR_IMGS[i].w} height={PILLAR_IMGS[i].h} />
        </div>
      </div>
    </section>
  ))}

  <section class="section alt endcta">
    <div class="container" style="text-align:center">
      <div class="rocket" aria-hidden="true">🚀</div>
      <h2>{t(locale, 'Try ', '即刻体验 ')}<span class="brand-mark">Apache APISIX</span>{t(locale, ' today.', '。')}</h2>
      <p style="margin-top:1.25rem"><a class="btn" href={`${p}/docs/apisix/getting-started/README/`}>{t(locale, 'Getting Started', '快速开始')}</a></p>
    </div>
  </section>
</Base>
