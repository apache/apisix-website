---
import Base from './Base.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import type { Post } from '../lib/content';
import { t, type Locale } from '../lib/site';

interface Props {
  title: string;
  heading: string;
  sub?: string;
  description?: string;
  kicker?: string;
  locale: Locale;
  path: string;       // canonical path without locale prefix
  base: string;       // pagination base WITH locale prefix
  posts: Post[];
  current: number;
  total: number;
  archiveUrl?: string;
  tagsUrl?: string;
}
const { title, heading, sub, description, kicker, locale, path, base, posts, current, total, archiveUrl, tagsUrl } = Astro.props;
---
<Base title={title} description={description ?? sub} locale={locale} path={path}>
  <header class="page-head">
    <div class="container">
      <div class="page-title">
        {kicker && <p class="kicker">{kicker}</p>}
        <h1>{heading}</h1>
        {sub && <p>{sub}</p>}
        {(archiveUrl || tagsUrl) && (
          <p class="tag-row">
            {archiveUrl && <a class="tag" href={archiveUrl}>{t(locale, 'Archive', '归档')}</a>}
            {tagsUrl && <a class="tag" href={tagsUrl}>{t(locale, 'All tags', '全部标签')}</a>}
          </p>
        )}
      </div>
    </div>
  </header>
  <div class="container">
    <div class="post-list">
      {posts.map((post, i) => <PostCard post={post} eager={current === 1 && i < 3} />)}
    </div>
    <Pagination current={current} total={total} base={base} locale={locale} />
  </div>
</Base>
