---
import Base from '../layouts/Base.astro';
// The /edit/ helper turns "#https://github.com/..." into a redirect to the
// GitHub editor. It is a utility page (noindex) and the one place a few lines
// of inline JS are genuinely required.
---
<Base title="Edit this page" locale="en" path="/edit/" noindex hasAlternate={false}>
  <div class="container article-wrap">
    <article class="prose">
      <h1>Redirecting to GitHub…</h1>
      <p>If you are not redirected automatically, the link that brought you here is missing its target. <a href="https://github.com/apache/apisix">Open the APISIX repository instead.</a></p>
    </article>
  </div>
  <script is:inline>
    var target = window.location.hash.slice(1);
    if (target.indexOf('https://github.com/apache/') === 0) window.location.replace(target);
  </script>
</Base>
