---
import Article from '../../../layouts/Article.astro';
import { getArticles } from '../../../lib/content';

export function getStaticPaths() {
  return getArticles('zh').map((post) => ({ params: { slug: post.slug }, props: { post } }));
}
const { post } = Astro.props;
---
<Article post={post} locale="zh" path={`/articles/${post.slug}/`} schemaType="Article" />
