---
import ListPage from '../../../../layouts/ListPage.astro';
import { getLearningPosts, groupByTag } from '../../../../lib/content';

export function getStaticPaths() {
  const tags = groupByTag(getLearningPosts('zh'));
  return [...tags.entries()].map(([slug, group]) => ({ params: { tag: slug }, props: group }));
}
const { label, posts } = Astro.props;
const tag = Astro.params.tag;
---
<ListPage
  title={`${label} | Learning Center`}
  heading={`Tag: ${label}`}
  locale="zh"
  path={`/learning-center/tags/${tag}/`}
  base={`/zh/learning-center/tags/${tag}/`}
  posts={posts}
  current={1}
  total={1}
/>
