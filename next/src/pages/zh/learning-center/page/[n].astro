---
import CollectionPages from '../../../../components/CollectionPages.astro';
import { getLearningPosts, paginate } from '../../../../lib/content';

export function getStaticPaths() {
  return paginate(getLearningPosts('zh')).slice(1).map((_, i) => ({ params: { n: String(i + 2) } }));
}
---
<CollectionPages
  locale="zh"
  page={Number(Astro.params.n)}
  posts={getLearningPosts('zh')}
  urlBase="/learning-center"
  heading="学习中心"
  kicker="学习中心"
  withTags
/>
