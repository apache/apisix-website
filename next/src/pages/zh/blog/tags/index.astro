---
import Base from '../../../../layouts/Base.astro';
import { getBlogPosts, groupByTag } from '../../../../lib/content';

const tags = groupByTag(getBlogPosts('zh'));
const sorted = [...tags.entries()].sort((a, b) => b[1].posts.length - a[1].posts.length || a[0].localeCompare(b[0]));
---
<Base title="标签 | 博客" locale="zh" path="/blog/tags/">
  <header class="page-head">
    <div class="container">
      <div class="page-title">
        <p class="kicker">博客</p>
        <h1>博客标签</h1>
      </div>
    </div>
  </header>
  <div class="container">
    <nav class="tag-row tag-cloud" aria-label="标签">
      {sorted.map(([slug, { label, posts }]) => (
        <a class="tag" href={`/zh/blog/tags/${slug}/`}>{label} <span class="count">{posts.length}</span></a>
      ))}
    </nav>
  </div>
</Base>
