---
import ListPage from '../../../../layouts/ListPage.astro';
import { getBlogPosts, groupByTag } from '../../../../lib/content';

export function getStaticPaths() {
  const tags = groupByTag(getBlogPosts('zh'));
  return [...tags.entries()].map(([slug, group]) => ({ params: { tag: slug }, props: group }));
}
const { label, posts } = Astro.props;
const tag = Astro.params.tag;
---
<ListPage
  title={`${label} | 博客`}
  heading={label}
  kicker={'标签'}
  sub={`${posts.length} 篇文章`}
  locale="zh"
  path={`/blog/tags/${tag}/`}
  base={`/zh/blog/tags/${tag}/`}
  posts={posts}
  current={1}
  total={1}
  tagsUrl={'/zh/blog/tags/'}
/>
