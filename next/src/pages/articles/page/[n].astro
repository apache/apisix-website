---
import CollectionPages from '../../../components/CollectionPages.astro';
import { getArticles, paginate } from '../../../lib/content';

export function getStaticPaths() {
  return paginate(getArticles('en')).slice(1).map((_, i) => ({ params: { n: String(i + 2) } }));
}
---
<CollectionPages
  locale="en"
  page={Number(Astro.params.n)}
  posts={getArticles('en')}
  urlBase="/articles"
  heading="Articles"
/>
