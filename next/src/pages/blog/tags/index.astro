---
import Base from '../../../layouts/Base.astro';
import { getBlogPosts, groupByTag } from '../../../lib/content';

const tags = groupByTag(getBlogPosts('en'));
const sorted = [...tags.entries()].sort((a, b) => b[1].posts.length - a[1].posts.length || a[0].localeCompare(b[0]));
---
<Base title="Tags | Blog" locale="en" path="/blog/tags/">
  <header class="page-head">
    <div class="container">
      <div class="page-title">
        <p class="kicker">Blog</p>
        <h1>Blog tags</h1>
      </div>
    </div>
  </header>
  <div class="container">
    <nav class="tag-row tag-cloud" aria-label="Tags">
      {sorted.map(([slug, { label, posts }]) => (
        <a class="tag" href={`/blog/tags/${slug}/`}>{label} <span class="count">{posts.length}</span></a>
      ))}
    </nav>
  </div>
</Base>
