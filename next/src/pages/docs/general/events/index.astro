---
import Base from '../../../../layouts/Base.astro';
import { getGeneralDocs } from '../../../../lib/content';

const events = getGeneralDocs('en')
  .filter((d) => d.id.startsWith('events/'))
  .sort((a, b) => b.id.localeCompare(a.id));
---
<Base title="Events" description="Apache APISIX meetups, conferences, and workshops." locale="en" path="/docs/general/events/">
  <div class="container">
    <div class="page-title"><h1>Events</h1><p>Apache APISIX meetups, conferences, and workshops.</p></div>
    <div class="post-list">
      {events.map((e) => (
        <a class="post-card" href={e.url}>
          <div class="body">
            <h3>{e.title}</h3>
            {e.description && <p class="desc">{e.description}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
