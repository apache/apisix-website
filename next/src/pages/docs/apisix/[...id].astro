---
import DocPage from '../../../layouts/DocPage.astro';
import { getApisixDocs, getApisixSidebar, APISIX_DOCS_VERSION } from '../../../lib/content';

export function getStaticPaths() {
  const docs = getApisixDocs('en');
  // Sidebar config ids are path-derived; map them to post-override titles/urls.
  const titleById = new Map(docs.map((d) => [d.pathId, d.title]));
  const urlByPathId = new Map(docs.map((d) => [d.pathId, d.url]));
  return docs.map((entry) => ({
    params: { id: entry.id },
    props: { entry, titleById, urlByPathId },
  }));
}
const { entry, titleById, urlByPathId } = Astro.props;
const sidebar = getApisixSidebar();
const urlById = (id: string) => urlByPathId.get(id) ?? `/docs/apisix/${id}/`;
const editUrl = `https://github.com/apache/apisix/edit/master/docs/en/latest/${entry.id}.md`;
---
<DocPage
  entry={entry}
  activeId={entry.pathId}
  locale="en"
  path={`/docs/apisix/${entry.id}/`}
  sidebar={sidebar}
  titleById={titleById}
  urlById={urlById}
  editUrl={editUrl}
  versionLabel={`APISIX ${APISIX_DOCS_VERSION}`}
/>
